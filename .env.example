# Copy this file to .env and replace placeholder values before running docker-compose.prod.yml

# Docker Hub image namespace
DOCKER_USERNAME=rebecca2745

# Authentication
JWT_SECRET=replace-with-strong-production-secret

# PostgreSQL
POSTGRES_DB=sharecraft
POSTGRES_USER=sharecraft_user
POSTGRES_PASSWORD=replace-with-strong-db-password

# Optional VM deployment values
PROD_SERVER_IP=your-vm-public-ip
PROD_SERVER_USER=ubuntu
PROD_SSH_KEY=stored-in-github-actions-secrets-not-here